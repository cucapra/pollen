.decl direction(name: symbol)
direction("forward").
direction("backward").

.type index = number

.decl segment(name: symbol)
.decl path(name: symbol)
.decl gfa(path: symbol, idx: index, direction: symbol, segment: symbol)

.input segment(filename="segments.csv")
.input path(filename="paths.csv")
.input gfa(filename="gfa.csv", delimiter=",")
